generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  TEACHER
}

enum ShopItemType {
  HEALTH
  HINT
  SKIP
}

enum EnrollmentStatus {
  ACTIVE
  REMOVED
}

enum QuestAttemptStatus {
  ACTIVE
  COMPLETED
  FAILED
}

enum ActivityType {
  QUEST
  ASSIGNMENT
  PRE_TEST
  ASSESSMENT
}

enum ContentType {
  ASSIGNMENT
  PRETEST
  ASSESSMENT
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  IDENTIFICATION
  MATCHING
  ENUMERATION
  SHORT_ANSWER
  ESSAY
}

enum SubmissionType {
  FILE_UPLOAD
  ESSAY
  SHORT_ANSWER
  MULTIPLE_CHOICE
  ATTACHMENTS
}

enum SubmissionStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  COMPLETED
  OVERDUE
  GRADED
}

model User {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  password    String
  role        UserRole
  avatarUrl   String?
  xp          Int       @default(0)
  coins       Int       @default(50)
  hintTokens  Int       @default(3)
  hearts      Int       @default(3)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  taughtSections      ClassSection[]       @relation("TeacherSections")
  studentSections     Enrollment[]
  questGuides         QuestGuide[]         @relation("TeacherQuestGuides")
  quests              Quest[]              @relation("TeacherQuests")
  progressRecords     StudentProgress[]
  answerAttempts      AnswerAttempt[]
  shopPurchases       ShopPurchase[]
  questAttempts       QuestAttempt[]
  questionProgress    QuestionProgress[]
  classContents       ClassContent[]       @relation("TeacherContent")
  contentAttempts     ContentAttempt[]
  activities          Activity[]
  activitySubmissions ActivitySubmission[] @relation("StudentSubmissions")

  @@index([role])
}

model ClassSection {
  id          String   @id @default(cuid())
  name        String
  description String?
  code        String   @unique
  teacherId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher             User                 @relation("TeacherSections", fields: [teacherId], references: [id], onDelete: Cascade)
  studentSections     Enrollment[]
  questGuides         QuestGuide[]
  quests              Quest[]
  progressRecords     StudentProgress[]
  answerAttempts      AnswerAttempt[]
  questAttempts       QuestAttempt[]
  questionProgress    QuestionProgress[]
  classContents       ClassContent[]
  contentAttempts     ContentAttempt[]
  activities          Activity[]
  activitySubmissions ActivitySubmission[]

  @@unique([teacherId, name])
  @@index([teacherId])
  @@map("Class")
}

model Enrollment {
  id        String           @id @default(cuid())
  studentId String
  sectionId String
  joinedAt  DateTime         @default(now())
  status    EnrollmentStatus @default(ACTIVE)
  grade     Float?

  student User         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section ClassSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([studentId, sectionId])
  @@index([sectionId])
  @@index([studentId])
  @@index([status])
  @@map("StudentSection")
}

model QuestGuide {
  id               String   @id @default(cuid())
  title            String
  topic            String
  shortExplanation String
  exampleProblem   String
  solutionSteps    String[]
  tips             String[]
  imageUrl         String?
  teacherId        String
  sectionId        String   @map("classId")
  questId          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  teacher       User         @relation("TeacherQuestGuides", fields: [teacherId], references: [id], onDelete: Cascade)
  section       ClassSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  featuredQuest Quest?       @relation("GuideFeaturedQuest", fields: [questId], references: [id], onDelete: SetNull)
  quests        Quest[]      @relation("QuestGuideLink")

  @@index([teacherId])
  @@index([sectionId])
  @@index([questId])
}

model Quest {
  id                   String   @id @default(cuid())
  title                String
  worldName            String
  topic                String
  difficulty           String
  requiredPuzzlePieces Int
  maxHearts            Int      @default(3)
  hintLimit            Int      @default(3)
  xpReward             Int      @default(100)
  coinReward           Int      @default(50)
  levelNumber          Int
  isPublished          Boolean  @default(false)
  teacherId            String
  sectionId            String   @map("classId")
  guideId              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  teacher          User               @relation("TeacherQuests", fields: [teacherId], references: [id], onDelete: Cascade)
  section          ClassSection       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  guide            QuestGuide?        @relation("QuestGuideLink", fields: [guideId], references: [id], onDelete: SetNull)
  guideReferences  QuestGuide[]       @relation("GuideFeaturedQuest")
  questions        QuestQuestion[]
  progress         StudentProgress[]
  answerAttempts   AnswerAttempt[]
  shopPurchases    ShopPurchase[]
  attempts         QuestAttempt[]
  questionProgress QuestionProgress[]
  activity         Activity?

  @@unique([sectionId, levelNumber])
  @@index([teacherId])
  @@index([sectionId])
  @@index([guideId])
}

model QuestQuestion {
  id            String   @id @default(cuid())
  questId       String
  equation      String
  choices       String[]
  correctAnswer String
  explanation   String   @default("")
  solutionSteps String[]
  difficulty    String
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  quest            Quest              @relation(fields: [questId], references: [id], onDelete: Cascade)
  answerAttempts   AnswerAttempt[]
  questionProgress QuestionProgress[]

  @@index([questId])
}

model StudentProgress {
  id              String    @id @default(cuid())
  studentId       String
  sectionId       String
  questId         String
  guideViewed     Boolean   @default(false)
  questUnlocked   Boolean   @default(false)
  questCompleted  Boolean   @default(false)
  score           Int       @default(0)
  xp              Int       @default(0)
  coins           Int       @default(50)
  coinsEarned     Int       @default(0)
  puzzlePieces    Int       @default(0)
  heartsRemaining Int       @default(3)
  hintTokens      Int       @default(3)
  hintsUsed       Int       @default(0)
  correctAnswers  Int       @default(0)
  wrongAnswers    Int       @default(0)
  accuracy        Float     @default(0)
  timeSpent       Int       @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  student User         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section ClassSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  quest   Quest        @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@unique([studentId, sectionId, questId])
  @@index([sectionId])
  @@index([questId])
}

model QuestAttempt {
  id          String             @id @default(cuid())
  studentId   String
  sectionId   String
  questId     String
  attemptNo   Int
  status      QuestAttemptStatus @default(ACTIVE)
  startedAt   DateTime           @default(now())
  completedAt DateTime?
  failedAt    DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  student          User               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section          ClassSection       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  quest            Quest              @relation(fields: [questId], references: [id], onDelete: Cascade)
  questionProgress QuestionProgress[]

  @@unique([studentId, questId, attemptNo])
  @@index([studentId, sectionId, questId, status])
  @@index([sectionId])
  @@index([questId])
}

model QuestionProgress {
  id             String    @id @default(cuid())
  attemptId      String
  studentId      String
  sectionId      String
  questId        String
  questionId     String
  selectedAnswer String?
  isCorrect      Boolean?
  hintsRevealed  Int       @default(0)
  answeredAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  attempt  QuestAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  student  User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section  ClassSection  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  quest    Quest         @relation(fields: [questId], references: [id], onDelete: Cascade)
  question QuestQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([studentId, sectionId, questId])
  @@index([questionId])
}

model AnswerAttempt {
  id             String   @id @default(cuid())
  studentId      String
  sectionId      String
  questId        String
  questionId     String
  selectedAnswer String
  isCorrect      Boolean
  createdAt      DateTime @default(now())

  student  User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section  ClassSection  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  quest    Quest         @relation(fields: [questId], references: [id], onDelete: Cascade)
  question QuestQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([studentId, sectionId, questId])
  @@index([studentId, questId])
  @@index([questionId])
}

model Activity {
  id            String       @id @default(cuid())
  type          ActivityType
  title         String
  description   String?
  dueDate       DateTime?
  availableFrom DateTime?
  availableTo   DateTime?
  totalPoints   Int?
  isPublished   Boolean      @default(false)
  orderIndex    Int          @default(0)
  teacherId     String
  sectionId     String
  questId       String?      @unique
  contentId     String?      @unique
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  teacher     User                 @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  section     ClassSection         @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  quest       Quest?               @relation(fields: [questId], references: [id], onDelete: SetNull)
  content     ClassContent?        @relation("ContentActivity", fields: [contentId], references: [id], onDelete: SetNull)
  submissions ActivitySubmission[]

  @@unique([sectionId, questId])
  @@unique([sectionId, contentId])
  @@index([teacherId])
  @@index([sectionId])
}

model ActivitySubmission {
  id              String           @id @default(cuid())
  activityId      String
  studentId       String
  sectionId       String
  score           Float?
  maxScore        Float?
  status          SubmissionStatus @default(NOT_STARTED)
  startedAt       DateTime?
  submittedAt     DateTime?
  gradedAt        DateTime?
  teacherFeedback String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  activity Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  student  User         @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  section  ClassSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([activityId, studentId])
  @@index([studentId])
  @@index([sectionId])
}

model ShopPurchase {
  id        String       @id @default(cuid())
  studentId String
  questId   String?
  itemType  ShopItemType
  cost      Int
  effect    String
  createdAt DateTime     @default(now())

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  quest   Quest? @relation(fields: [questId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([questId])
}

model ClassContent {
  id                  String         @id @default(cuid())
  title               String
  type                ContentType
  description         String?
  instructions        String?
  dueDate             DateTime?
  availableFrom       DateTime?
  availableTo         DateTime?
  submissionType      String?        @default("quiz")
  submissionTypes     SubmissionType[]
  timeLimitMinutes    Int?
  maxScore            Int?
  isPublished         Boolean        @default(false)
  passingScore        Int?
  shuffleQuestions    Boolean        @default(false)
  shuffleChoices      Boolean        @default(false)
  attemptsAllowed     Int            @default(1)
  showScoreImmediately Boolean       @default(true)
  randomQuestions     Int?
  autoGrade           Boolean        @default(true)
  teacherId           String
  sectionId           String
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  teacher   User              @relation("TeacherContent", fields: [teacherId], references: [id], onDelete: Cascade)
  section   ClassSection      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  questions ContentQuestion[]
  attempts  ContentAttempt[]
  activity  Activity?         @relation("ContentActivity")

  @@index([teacherId])
  @@index([sectionId])
}

model ContentQuestion {
  id               String       @id @default(cuid())
  contentId        String
  equation         String
  questionType     QuestionType @default(MULTIPLE_CHOICE)
  choices          String[]
  correctAnswer    String
  explanation      String       @default("")
  points           Int          @default(1)
  difficulty       String       @default("Medium")
  imageUrl         String?
  matchingPairs    Json?
  enumerationItems String[]
  isCorrect        Boolean?

  content ClassContent    @relation(fields: [contentId], references: [id], onDelete: Cascade)
  answers ContentAnswer[]

  @@index([contentId])
}

model ContentAttempt {
  id          String    @id @default(cuid())
  contentId   String
  studentId   String
  sectionId   String
  score       Int?
  maxScore    Int?
  status      String    @default("ACTIVE")
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  content ClassContent    @relation(fields: [contentId], references: [id], onDelete: Cascade)
  student User            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  section ClassSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  answers ContentAnswer[]

  @@index([contentId, studentId])
  @@index([studentId])
}

model ContentAnswer {
  id             String   @id @default(cuid())
  attemptId      String
  questionId     String
  selectedAnswer String?
  isCorrect      Boolean
  answeredAt     DateTime @default(now())

  attempt  ContentAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question ContentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([attemptId])
}
